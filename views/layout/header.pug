header#header.cc-header
  div.cc-header--inner.cc-content--wide
    h1.cc-header--title
      a( href= "/" )
        span.coin Coin
        span.collect Collect
    nav.cc-header--nav
      a( href= "/" )= t( '_.nav.dashboard' )
      a( href= "/stats" )= t( '_.nav.stats' )
      a( href= "/add" )= t( '_.nav.add' )
      a( href= "/settings" )= t( '_.nav.settings' )
