append styles
  link( rel= "stylesheet", href= "/css/components/material.css" )

mixin material( materials )
  div.cc-mixin.cc-mixin--material
    div.cc-mixin--material-chart
      each m, i in materials
        div.cc-mixin--material-chart-item( material= m.material, style= "--p: " + m.portion )
    ul.cc-mixin--material-legend
      each m, i in materials
        li.cc-mixin--material-legend-item( material= m.material )
          - let fineness = m.fineness ? formatter.number( m.fineness, 1 ) + ' ' : ''
          - let portion = ' (' + formatter.percent( m.portion, 1 ) + ')'
          a( href= '/#material=' + m.material )= fineness + t( '_.material.' + m.material ) + portion
