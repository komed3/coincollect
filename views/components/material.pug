append styles
  link( rel= "stylesheet", href= "/css/components/material.css" )

mixin material( materials )
  div.cc-mixin.cc-mixin--material
    div.cc-mixin--material-chart
      each m, i in materials
        div.cc-mixin--material-chart-item( color= m.key, style= "--p: " + m.portion )
    ul.cc-mixin--material-legend
      each m, i in materials
        li.cc-mixin--material-legend-item( color= m.key )
          span= formatter.number( m.fineness, 1 ) + ' ' + m.name + ' (' + formatter.percent( m.portion, 1 ) + ')'
