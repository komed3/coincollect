mixin text( name, label, val, req = false, classes = '', datalist = [] )
  div.cc-form--field( class= classes )
    label( for= '__' + name )= label + ( req ? ' *' : '' )
    input(
      type= 'text', name= name, value= val,
      required= req, id= '__' + name, autocomplete= 'on',
      list= datalist.length ? '__' + name + '-list' : undefined
    )
    if datalist.length
      datalist( id= '__' + name + '-list' )
        each item in datalist
          option( value= item )= item

mixin number( name, label, val, req = false, classes = '', min = 0, max = undefined, step = 0.01 )
  div.cc-form--field( class= classes )
    label( for= '__' + name )= label + ( req ? ' *' : '' )
    input(
      type= 'number', name= name, value= val, min= min, max= max, step= step,
      required= req, id= '__' + name, autocomplete= 'off'
    )

mixin date( name, label, val, req = false, classes = '' )
  div.cc-form--field( class= classes )
    label( for= '__' + name )= label + ( req ? ' *' : '' )
    input(
      type= 'date', name= name, value= val && new Date( val ).toISOString().split( 'T' )[ 0 ],
      required= req, id= '__' + name, autocomplete= 'off'
    )

mixin checkbox( name, label, val, req = false, classes = '' )
  div.cc-form--field( class= classes )
    label.cc-form--checkbox
      input( type= 'checkbox', name= name, checked= val, required= req )
      i.fa.fa-check
      span= label

mixin textarea( name, label, val, req = false, classes = '' )
  div.cc-form--field( class= classes )
    label( for= '__' + name )= label + ( req ? ' *' : '' )
    textarea( name= name, required= req, id= '__' + name )= val

mixin select( name, label, keys, val, req = false, classes = '' )
  div.cc-form--field( class= classes )
    label( for= '__' + name )= label + ( req ? ' *' : '' )
    select( name= name, required= req, id= '__' + name )
      option( value= '' )= t( 'editor.select' )
      option( disabled ) ──────────
      each k in keys
        - let n = name.split( '__' )[ 0 ]
        option( value= k, selected= ( k === val ) )= t( '_.' + n + '.' + k )

mixin file( name, label, val, req = false, classes = '' )
  div.cc-form--field.cc-form--image( id= name )
    input( type= 'file', name= name, id= '__' + name )
    label( for= '__' + name )
      i.fa.fa-upload
      span= label
    button( title= t( 'editor.delete' ) ): i.fa.fa-trash-o
