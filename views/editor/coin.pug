extends ../layout/page
include ../components/form

append styles
  link( rel= "stylesheet", href= "/css/editor.css" )

block main
  div.cc-editor.cc-content--normal
    div.cc-editor--nav
      a( href= "/add/base" )= t( 'editor.nav.base' )
      a.current( href= "/add/coin" )= t( 'editor.nav.coin' )

    form.cc-editor--form( autocomplete= "on" )
      div.cc-box
        h3.cc-box--hl= t( 'editor.coin.info.headline' )
        div.cc-form--row
          // base ID
        div.cc-form--row
          +select( 'status', t( 'editor.coin.info.status' ), keys.status, undefined, true, 'x2' )
          +select( 'grade', t( 'editor.coin.info.grade' ), keys.grade, undefined, true, 'x2' )
          +number( 'amount', t( 'editor.coin.info.amount' ), 1, true )
