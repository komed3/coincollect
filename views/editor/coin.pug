extends ../layout/page
include ../components/form

append styles
  link( rel= "stylesheet", href= "/css/form.css" )
  link( rel= "stylesheet", href= "/css/editor.css" )

block main
  div.cc-editor.cc-content--normal
    div.cc-editor--nav
      a( href= "/add/base" )= t( 'editor.nav.base' )
      a.current( href= "/add/coin" )= t( 'editor.nav.coin' )

    form.cc-editor--form( autocomplete= "on" )
      div.cc-box
        h3.cc-box--hl= t( 'editor.coin.info.headline' )
        div.cc-form--row
          div.cc-form--field
            label( for= "__baseId" )= t( 'editor.coin.info.baseId' ) + ' *'
            select( name= "baseId", required= true, id= "__baseId" )
              option( value= "" )= t( 'editor.select' )
              option( disabled ) ──────────
              each base in coinBases
                option( value= base.id )= base.name + ' (#' + base.id + ')'

        div.cc-form--row
          +select( 'status', t( 'editor.coin.info.status' ), keys.status, undefined, true, 'x2' )
          +select( 'grade', t( 'editor.coin.info.grade' ), keys.grade, undefined, true, 'x2' )
          +number( 'amount', t( 'editor.coin.info.amount' ), 1, true )
        div.cc-form--row
          +checkbox( 'certified', t( 'editor.coin.info.certified' ), undefined, false )

      div.cc-box
        h3.cc-box--hl= t( 'editor.coin.extra.headline' )
        div.cc-form--row
          +textarea( 'notes', t( 'editor.coin.extra.notes' ), undefined, false )

      div.cc-form--actions
        button.cc-form--submit( type= "submit" )= t( '_.actions.submit' )
        button.cc-form--abort( type= "reset" )= t( '_.actions.abort' )
