extends ../layout/page
include ../components/barcode
include ../components/chart
include ../components/material

append styles
  link( rel= "stylesheet", href= "/css/coin.css" )

block main
  div.cc-coin.cc-content--normal
    div.cc-coin--header
      h1.cc-coin--header-title= base.name
      div.cc-coin--header-actions
        a.current( href= `/coin/${coin.id}` )= t( 'view.actions.view' )
        a( href= `/base/${base.id}` )= t( 'view.actions.base' )
        a( href= `/coin/${coin.id}/edit` )= t( 'view.actions.edit' )
        a( href= `/coin/${coin.id}/delete` )= t( 'view.actions.delete' )

    div.cc-coin--content
      dic.cc-coin--main
        div.cc-box.cc-coin--info
          h3.cc-box--hl= t( 'view.coin.info.headline' )
          ul.cc-list
            if base.type
              li
                span= t( 'view.coin.info.type' )
                b: a( href= '/#type='+ base.type )= t( '_.type.' + base.type )
            if coin.status
              li
                span= t( 'view.coin.info.status' )
                b: a( href= '/#status='+ coin.status )= t( '_.status.' + coin.status ) + ' (' + coin.amount + 'x)'
            if coin.certified
              li
                span= t( 'view.coin.info.certificate' )
                if coin.certIssuer
                  b= t( 'view.coin.info.certified', { issuer: coin.certIssuer, number: coin.certNumber || '—' } )
                else
                  b= t( 'view.coin.info.certifiedUnknown' )
            if coin.grade
              li
                span= t( 'view.coin.info.grade' )
                b: a( href= '/#grade='+ coin.grade )= t( '_.grade.' + coin.grade )
            if base.series
              li
                span= t( 'view.coin.info.series' )
                b: a( href= '/#series='+ base.series )= base.series
            if base.country
              li
                span= t( 'view.coin.info.country' )
                b: a( href= '/#country='+ base.country )= base.country
            if base.currency
              li
                span= t( 'view.coin.info.currency' )
                b: a( href= '/#currency='+ base.currency )= base.currency
            if base.nominal && base.nominal.value && base.nominal.unit
              li
                span= t( 'view.coin.info.nominal' )
                b= base.nominal.value + ' ' + base.nominal.unit
            if coin.notes
              li.column
                span= t( 'view.coin.info.notes' )
                p= coin.notes

        if base.tags && base.tags.length
          div.cc-coin--tags
            each tag in base.tags
              a( href= '/#tag=' + tag )= tag

        if coin.acquisition || ( coin.value && coin.value.length )
          div.cc-box.cc-coin--value
            h3.cc-box--hl= t( 'view.coin.value.headline' )
            div.cc-coin--value-container
              div.cc-coin--value-list
                ul.cc-list
                  if coin.acquisition && coin.acquisition.method && coin.acquisition.date
                    li.column
                      span= t( 'view.coin.value.acquisition' )
                      b= t( '_.acquisition.' + coin.acquisition.method ) + ', ' + formatter.date( coin.acquisition.date )
                  if coin.acquisition && coin.acquisition.price
                    li.column.big
                      span= t( 'view.coin.value.price' )
                      b= formatter.money( currency, coin.acquisition.price )
                  if coin.value && coin.value.length
                    li.column.big
                      span= t( 'view.coin.value.value' )
                      b= formatter.money( currency, coin.value[ 0 ].price )
                    if coin.acquisition && coin.acquisition.price
                      li.column.big
                        span= t( 'view.coin.value.growth' )
                        b= formatter.percent( coin.value[ 0 ].price / coin.acquisition.price * 100 - 100 )
              if coin.value && coin.value.length
                div.cc-coin--value-graph
                  +chart( 'value', { acquisition: coin.acquisition, value: coin.value } )

        if base.dimension || ( base.design && base.design.shape ) || base.material
          div.cc-box.cc-coin--specs
            h3.cc-box--hl= t( 'view.coin.specs.headline' )
            ul.cc-list
              if base.design && base.design.shape
                li
                  span= t( 'view.coin.design.shape' )
                  b= t( '_.shape.' + base.design.shape )
              if base.dimension && base.dimension.diameter
                li
                  span= t( 'view.coin.specs.diameter' )
                  b= formatter.unit( 'millimeter', base.dimension.diameter )
              if base.dimension && base.dimension.thickness
                li
                  span= t( 'view.coin.specs.thickness' )
                  b= formatter.unit( 'millimeter', base.dimension.thickness )
              if base.dimension && base.dimension.weight
                li
                  span= t( 'view.coin.specs.weight' )
                  b= formatter.unit( 'gram', base.dimension.weight )
              if base.material
                li.column
                  span= t( 'view.coin.specs.material' )
                  +material( base.material )

        if base.issuer || base.issueDate || base.devaluationDate || coin.mintMark || coin.mintYear || coin.mintage
          div.cc-box.cc-coin--mint
            h3.cc-box--hl= t( 'view.coin.mint.headline' )
            ul.cc-list
              if base.issuer
                li
                  span= t( 'view.coin.mint.issuer' )
                  b: a( href= "/#issuer=" + base.issuer )= base.issuer
              if base.issueDate
                li
                  span= t( 'view.coin.mint.issueDate' )
                  b= formatter.date( base.issueDate )
              if base.devaluationDate
                li
                  span= t( 'view.coin.mint.devaluationDate' )
                  b= formatter.date( base.devaluationDate )
              if coin.mintage
                li
                  span= t( 'view.coin.mint.mintage' )
                  b= formatter.number( coin.mintage, 0 )
              if coin.mintMark
                li
                  span= t( 'view.coin.mint.mintMark' )
                  b= coin.mintMark
              if coin.mintYear
                li
                  span= t( 'view.coin.mint.mintYear' )
                  b= coin.mintYear

        if base.description || ( base.design && ( base.design.obverse || base.design.reverse || base.design.edge ) )
          div.cc-box.cc-coin--design
            h3.cc-box--hl= t( 'view.coin.design.headline' )
            ul.cc-list
              if base.design && base.design.obverse
                li.column
                  span= t( 'view.coin.design.obverse' )
                  p= base.design.obverse
              if base.design && base.design.reverse
                li.column
                  span= t( 'view.coin.design.reverse' )
                  p= base.design.reverse
              if base.design && base.design.edge
                li.column
                  span= t( 'view.coin.design.edge' )
                  p= base.design.edge
              if base.description
                li.column
                  span= t( 'view.coin.design.description' )
                  p= base.description

      div.cc-coin--aside
        div.cc-coin--barcode
          +barcode( coin.id )

        if base.image && base.image.obverse
          figure.cc-coin--image
            img( src= '/uploads/' + base.image.obverse, alt= t( 'view.coin.image.obverse' ) )
            figcaption= t( 'view.coin.image.obverse' )
        if base.image && base.image.reverse
          figure.cc-coin--image
            img( src= '/uploads/' + base.image.reverse, alt= t( 'view.coin.image.reverse' ) )
            figcaption= t( 'view.coin.image.reverse' )
        if base.image && base.image.other
          figure.cc-coin--image
            img( src= '/uploads/' + base.image.other, alt= t( 'view.coin.image.other' ) )
            figcaption= t( 'view.coin.image.other' )

        if base.identifier && base.identifier.length
          div.cc-coin--identifier
            h3.cc-box--hl= t( 'view.coin.identifier.headline' )
            ul.cc-list
              each id in base.identifier
                li.column
                  span= id.catalog
                  b= t( 'view.coin.identifier.number', { number: id.id } )
