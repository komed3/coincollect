{
  "name": "@komed3/coincollect",
  "description": "Web app for managing coin collections",
  "private": true,
  "license": "MIT",
  "version": "0.1.0-alpha",
  "author": {
    "name": "komed3 (Paul Köhler)",
    "email": "webmaster@komed3.de",
    "url": "https://komed3.de"
  },
  "homepage": "https://github.com/komed3/coincollect",
  "keywords": [
    "coin",
    "collection",
    "coin-collection"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komed3/coincollect.git"
  },
  "bugs": {
    "url": "https://github.com/komed3/coincollect/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "cd server && npm run start",
    "start:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "concurrently": "^9.2.1"
  }
}
